{
  "name": "mongo-migration-runner",
  "version": "1.0.0",
  "description": "Production-grade MongoDB migration runner with tamper protection, dry-run, and audit logging",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint '../migrations/**/*.js' --no-eslintrc -c .eslintrc.json",
    "migrate": "node dist/index.js",
    "validate": "node dist/index.js --validate"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "mongodb": "^6.12.0",
    "glob": "^10.4.5"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^20.17.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0"
  }
}
